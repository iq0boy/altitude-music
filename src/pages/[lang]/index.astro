---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Marquee from '../../components/Marquee.astro';
import Services from '../../components/Services.astro';
import About from '../../components/About.astro';
import Blog from '../../components/Blog.astro';
import Footer from '../../components/Footer.astro';
import SectionHead from '../../components/SectionHead.astro';
import Portfolio from '../../components/Portfolio';
import MediaGrid from '../../components/MediaGrid.astro';
import Testimonials from '../../components/Testimonials';
import Booking from '../../components/Booking';
import Contact from '../../components/Contact';
import ServiceDetail from '../../components/ServiceDetail';
import { getCollection, getEntry } from 'astro:content';
import { getTranslations, LANGS } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import type { ServiceData, TeamMember, TestimonialData } from '../../data/services';


export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

const siteSettings = await getEntry('settings', 'site');
const heroVideo = siteSettings?.data.heroVideo;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => p.data.lang === lang)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

const musicEntries = await getCollection('music');
const tracks = musicEntries
  .map(e => ({ id: e.id, ...e.data }))
  .sort((a, b) => a.sortOrder - b.sortOrder);

const mediaItems = (await getCollection('media'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const serviceList = (await getCollection('services'))
  .map(e => e.data as ServiceData)
  .sort((a, b) => a.sortOrder - b.sortOrder);

const teamMembers = (await getCollection('team'))
  .map(e => e.data as TeamMember)
  .sort((a, b) => a.sortOrder - b.sortOrder);

const testimonials = (await getCollection('testimonials'))
  .map(e => e.data as TestimonialData)
  .sort((a, b) => a.sortOrder - b.sortOrder);

const SITE = 'https://altitudemusic.be';
const inLanguage = lang === 'fr' ? 'fr-BE' : lang === 'nl' ? 'nl-BE' : 'en-BE';

const serviceNodes = serviceList.map(s => {
  const offer = s.price === 0
    ? { '@type': 'Offer', price: '0', priceCurrency: 'EUR', availability: 'https://schema.org/InStock' }
    : s.price === -1
      ? { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', priceCurrency: 'EUR' } }
      : { '@type': 'Offer', price: String(s.price), priceCurrency: 'EUR', availability: 'https://schema.org/InStock', url: `${SITE}/${lang}/#service/${s.key}` };
  return {
    '@type': 'Service',
    '@id': `${SITE}/${lang}/#service-${s.key}`,
    name: s.name[lang],
    description: s.desc[lang],
    serviceType: s.name[lang],
    provider: { '@id': `${SITE}/#studio` },
    areaServed: { '@type': 'Country', name: 'Belgium' },
    offers: offer,
  };
});

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: SITE,
      name: 'Altitude Music',
      inLanguage,
      publisher: { '@id': `${SITE}/#studio` },
    },
    ...serviceNodes,
  ],
};
---

<BaseLayout lang={lang} title={t.meta.title} description={t.meta.description} jsonLd={homeJsonLd}>
  <Nav lang={lang} t={t.nav} />
  <main>
    <Hero t={t} heroVariant="video" heroVideo={heroVideo} />
    <Marquee words={t.marquee} />
    <Marquee words={['ENREGISTREMENT', 'MIX', 'MASTER', 'PROD', 'POCHETTES', 'CLIPS', 'MASTERING', 'LABEL']} variant="outline" />
    <Services t={t} lang={lang} services={serviceList} />

    <section class="section" id="work" style="border-top:1px solid var(--line)">
      <div class="container">
        <SectionHead tag="// 03" title={t.sections.portfolio} sub={t.sections.portfolioSub} />
        <Portfolio tracks={tracks} t={t} lang={lang} layout="list" client:visible />
      </div>
    </section>

    <section class="section" id="videos" style="border-top:1px solid var(--line)">
      <div class="container">
        <SectionHead tag="// 04" title={t.sections.videos} sub={t.sections.videosSub} />
        <MediaGrid items={mediaItems} />
      </div>
    </section>

    <About t={t} lang={lang} team={teamMembers} />

    <section class="section" id="testimonials" style="border-top:1px solid var(--line)">
      <div class="container">
        <SectionHead tag="// 06" title={t.sections.testimonials} sub={t.sections.testimonialsSub} />
        <Testimonials testimonials={testimonials} services={serviceList} t={t} lang={lang} client:visible />
      </div>
    </section>

    <Blog posts={posts} t={t} lang={lang} />

    <section class="section" id="booking" style="border-top:1px solid var(--line)">
      <div class="container">
        <SectionHead tag="// 08" title={t.sections.booking} sub={t.sections.bookingSub} />
        <Booking t={t} lang={lang} services={serviceList} client:visible />
      </div>
    </section>

    <section class="section" id="contact" style="border-top:1px solid var(--line)">
      <div class="container">
        <SectionHead tag="// 09" title={t.sections.contact} sub={t.sections.contactSub} />
        <Contact t={t} lang={lang} client:visible />
      </div>
    </section>
  </main>
  <Footer t={t} lang={lang} />
  <ServiceDetail
    t={t}
    lang={lang}
    services={serviceList}
    testimonials={testimonials}
    client:load
  />
</BaseLayout>
