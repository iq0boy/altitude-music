---
interface Props { words: readonly string[]; variant?: 'fill' | 'outline'; }
const { words, variant = 'fill' } = Astro.props;
const repeated = [...words, ...words, ...words, ...words];
---
<div class={`marquee${variant === 'outline' ? ' outline' : ''}`}>
  <div class="marquee-track">
    {repeated.map((w, i) => <span key={i}>{w}</span>)}
  </div>
</div>
