---
import SectionHead from './SectionHead.astro';
import type { Translations, Lang } from '../i18n/utils';
import type { ServiceData } from '../data/services';

interface Props { t: Translations; lang: Lang; services: ServiceData[]; }
const { t, lang, services } = Astro.props;
---
<section class="section" id="services">
  <div class="container">
    <SectionHead tag="// 02" title={t.sections.services} sub={t.sections.servicesSub} />
    <div class="services-grid">
      {services.map((s, i) => (
        <a
          href={`#service/${s.key}`}
          class={`service-card ${s.popular ? 'popular' : ''}`}
          data-popular={t.servicesUI.popular}
          aria-label={`${s.name[lang]} — ${t.serviceDetail.learnMore}`}
        >
          <div class="service-num">SVC / {String(i + 1).padStart(2, '0')}</div>
          <div class="service-name">{s.name[lang]}</div>
          <div class="service-desc">{s.desc[lang]}</div>
          <div class="service-price">
            {s.price === 0 ? (
              <span class="num">{s.unit[lang]}</span>
            ) : s.price === -1 ? (
              <span class="num">{t.servicesUI.quote}</span>
            ) : (
              <>
                <span class="from">{t.servicesUI.from}</span>
                <span class="num">€{s.price}</span>
                <span class="unit">{s.unit[lang]}</span>
              </>
            )}
          </div>
          <span class="service-cta">{t.serviceDetail.learnMore}</span>
        </a>
      ))}
    </div>
  </div>
</section>
