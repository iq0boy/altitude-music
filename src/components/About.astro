---
import SectionHead from './SectionHead.astro';
import type { Translations, Lang } from '../i18n/utils';
import type { TeamMember } from '../data/services';

interface Props { t: Translations; lang: Lang; team: TeamMember[]; }
const { t, lang, team } = Astro.props;
---
<section class="section" id="about" style="border-top:1px solid var(--line)">
  <div class="container">
    <SectionHead tag="// 05" title={t.sections.about} sub={t.sections.aboutSub} />
    <div class="about-grid">
      <div class="about-text">
        <p><strong>{t.about.story}.</strong> {t.about.storyText}</p>
        <p><strong>{t.about.team}.</strong> {t.about.teamText}</p>
        <div class="stats">
          {t.about.stats.map(s => (
            <div class="stat">
              <div class="stat-n reveal">{s.n}</div>
              <div class="stat-l">{s.l}</div>
            </div>
          ))}
        </div>
      </div>
      <div class="team-grid">
        {team.map(m => (
          <a class="team-card" href={m.instagram} target="_blank" rel="noopener" aria-label={`${m.name} — @${m.handle} · ${m.role[lang]}`}>
            <div class="team-avatar" style={`--c:${m.color}`}>
              <span class="name">{m.name}</span>
            </div>
            <span class="team-role">{m.role[lang]}</span>
            <span class="team-handle">@{m.handle}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
