---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'social'>[];
  igProfileUrl: string;
  ttProfileUrl: string;
}
const { posts, igProfileUrl, ttProfileUrl } = Astro.props;

type Parsed = { platform: 'instagram' | 'tiktok'; embed: string; handle: string };

function parsePost(url: string): Parsed | null {
  const ig = url.match(/instagram\.com\/(p|reel|reels|tv)\/([A-Za-z0-9_-]+)/);
  if (ig) {
    const kind = ig[1] === 'reels' ? 'reel' : ig[1];
    return {
      platform: 'instagram',
      embed: `https://www.instagram.com/${kind}/${ig[2]}/embed/`,
      handle: '@alt_itude.music',
    };
  }
  const tt = url.match(/tiktok\.com\/@([A-Za-z0-9_.]+)\/video\/(\d{15,20})/);
  if (tt) {
    return {
      platform: 'tiktok',
      embed: `https://www.tiktok.com/player/v1/${tt[2]}?music_info=1&description=1`,
      handle: `@${tt[1]}`,
    };
  }
  return null;
}
---
<div class="ig-grid">
  {posts.map(p => {
    const parsed = parsePost(p.data.url);
    if (!parsed) return null;
    return (
      <a href={p.data.url} target="_blank" rel="noopener" class="ig-tile" data-platform={parsed.platform}>
        <div class="ig-embed" style={`aspect-ratio:${p.data.aspect}`}>
          <iframe
            src={parsed.embed}
            title={`${parsed.platform === 'tiktok' ? 'TikTok' : 'Instagram'} ${p.data.kind.toLowerCase()} — Altitude Music`}
            loading="lazy"
            allow="encrypted-media; picture-in-picture; web-share"
            allowfullscreen
            scrolling="no"
          />
        </div>
        <div class="ig-tag-row">
          <span class="ig-tag">{p.data.kind}</span>
          <span class="ig-open">{parsed.handle} ↗</span>
        </div>
      </a>
    );
  })}
</div>
<div class="ig-ctas">
  <a href={igProfileUrl} target="_blank" rel="noopener" class="ig-cta">Instagram →</a>
  <a href={ttProfileUrl} target="_blank" rel="noopener" class="ig-cta">TikTok →</a>
</div>
