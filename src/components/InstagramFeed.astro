---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'instagram'>[];
  profileUrl: string;
}
const { posts, profileUrl } = Astro.props;

function parseIg(url: string) {
  const m = url.match(/instagram\.com\/(p|reel|reels|tv)\/([A-Za-z0-9_-]+)/);
  if (!m) return null;
  const kind = m[1] === 'reels' ? 'reel' : m[1];
  return { kind, shortcode: m[2], embed: `https://www.instagram.com/${kind}/${m[2]}/embed/` };
}
---
<div class="ig-grid">
  {posts.map(p => {
    const parsed = parseIg(p.data.url);
    if (!parsed) return null;
    return (
      <a href={p.data.url} target="_blank" rel="noopener" class="ig-tile">
        <div class="ig-embed" style={`aspect-ratio:${p.data.aspect}`}>
          <iframe
            src={parsed.embed}
            title={`Instagram ${p.data.kind.toLowerCase()} — Altitude Music`}
            loading="lazy"
            allow="encrypted-media; picture-in-picture; web-share"
            allowfullscreen
            scrolling="no"
          />
        </div>
        <div class="ig-tag-row">
          <span class="ig-tag">{p.data.kind}</span>
          <span class="ig-open">@alt_itude.music ↗</span>
        </div>
      </a>
    );
  })}
</div>
<a href={profileUrl} target="_blank" rel="noopener" class="ig-cta">
  See more on Instagram →
</a>
